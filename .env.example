# FinFlow — Environment Variables
# Copy this file to .env and fill in your values before deploying.
# NEVER commit .env to git.

# ── Required — app will not start without these ───────────────────────────────

# PostgreSQL connection string. Local example: postgres://postgres:password@localhost:5432/finflow
# Render/Railway/Supabase will provide this automatically.
DATABASE_URL=postgres://user:password@host:5432/finflow

# Anthropic API key — powers the AI assistant and receipt scanner.
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# A long, random secret string used to sign session cookies.
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-string

# The exact origin your frontend runs on (e.g. https://finflow-production-dab1.up.railway.app).
# Used to lock down CORS. In development you can leave this unset.
ALLOWED_ORIGIN=https://finflow-production-dab1.up.railway.app

# ── Optional ──────────────────────────────────────────────────────────────────

# Set to 'production' on your server to enable secure cookies and other guards.
NODE_ENV=production

# Port the server listens on (defaults to 3000 if unset).
PORT=3000

# ── Email — Password Reset (Resend) ──────────────────────────────────────────
# Sign up free at https://resend.com — get an API key in ~2 minutes.
# Without this, reset links are logged to the server console instead of emailed.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The sender address shown in reset emails. Must be a verified domain in Resend.
EMAIL_FROM=FinFlow <noreply@yourdomain.com>

# The public URL of your app, used to build every outbound email/redirect link (F29).
# Single source of truth — set this to your canonical public origin.
APP_URL=https://finflow-production-dab1.up.railway.app

# ── Stripe — Billing ──────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys and your product price IDs.
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_BUSINESS=price_...

# ── Cron jobs ─────────────────────────────────────────────────────────────────
# Random secret used to authenticate scheduled cron requests.
CRON_SECRET=your_random_secret_here

# ── Admin ─────────────────────────────────────────────────────────────────────
# Password to log into the /admin panel. Set a strong value before deploying.
ADMIN_PASSWORD=your_secure_admin_password_here
# Email address that receives new accountant application notifications.
ADMIN_EMAIL=admin@yourdomain.com
