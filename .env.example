# FinFlow — Environment Variables
# Copy this file to .env and fill in your values before deploying.
# NEVER commit .env to git.

# ── Required in production ────────────────────────────────────────────────────

# A long, random secret string used to sign session cookies.
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-string

# The exact origin your frontend runs on (e.g. https://app.finflow.io).
# Used to lock down CORS. In development you can leave this unset.
ALLOWED_ORIGIN=https://app.finflow.io

# ── Optional ──────────────────────────────────────────────────────────────────

# Set to 'production' on your server to enable secure cookies and other guards.
NODE_ENV=production

# Port the server listens on (defaults to 3000 if unset).
PORT=3000

# ── Email — Password Reset (Resend) ──────────────────────────────────────────
# Sign up free at https://resend.com — get an API key in ~2 minutes.
# Without this, reset links are logged to the server console instead of emailed.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The sender address shown in reset emails. Must be a verified domain in Resend.
EMAIL_FROM=FinFlow <noreply@yourdomain.com>

# The public URL of your app, used to build the reset link in emails.
APP_URL=https://app.finflow.io
